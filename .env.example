FMP_API_KEY=your_api_key_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=changeme
MLFLOW_TRACKING_URI=http://localhost:5000
# Remote MLflow UI/API (Docker): Host header must be allowed or requests get 403. Comma-separated
# fnmatch patterns; include hostname or IP clients use (e.g. my-mac.local,192.168.1.10,localhost:*).
# Default in docker-compose is * (any host). Tighten for production.
# MLFLOW_SERVER_ALLOWED_HOSTS=my-mac.local,192.168.1.10,localhost:*
# Browser CORS for cross-origin API/UI; default * in docker-compose. Use explicit origins if needed.
# MLFLOW_SERVER_CORS_ALLOWED_ORIGINS=https://notebook.example.com,http://localhost:3000
PIPELINE_ENV=dev  # dev (5yr data) or prod (20yr data)
